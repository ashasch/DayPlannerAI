# ---- Database (Postgres) ----
# Either name works; DATABASE_URL wins if both are set.
# On Vercel, POSTGRES_URL is injected automatically when a Postgres database is
# attached — you do not need to set it there.
#
# Locally, the simplest option is to reuse the same Vercel database:
#   npx vercel link
#   npx vercel env pull .env.local
#
# Note: use the POOLED connection string for the app (it goes through PgBouncer),
# and the DIRECT/unpooled one for migrations if your provider distinguishes them.
DATABASE_URL=postgres://user:password@host:5432/dbname?sslmode=require

# ---- Auth.js (NextAuth) ----
# Generate with: npx auth secret   (or: openssl rand -base64 32)
AUTH_SECRET=

# Base URL of the app. Required in production, optional locally.
# AUTH_URL=http://localhost:3000

# ---- AI (OpenRouter) ----
# The API key is read ONLY from this variable and never leaves the server.
# Get one at https://openrouter.ai/keys — it starts with `sk-or-`.
#
# We talk to OpenRouter's Anthropic-compatible /v1/messages endpoint using
# @anthropic-ai/sdk, so model ids must be OpenRouter-namespaced.
OPENROUTER_API_KEY=
# Optional override of the default model.
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
